{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Information"
    }
  },
  "IdentityServer": {
    "Authority": "http://identity-svc"
  },
  "ReverseProxy": {
    "Clusters": {
      "auctions": {
        "Destinations": {
          "auctionapi": {
            "Address": "http://auction-svc"
          }
        }
      },
      "search": {
        "Destinations": {
          "searchapi": {
            "Address": "http://search-svc"
          }
        }
      },
      "bids": {
        "Destinations": {
          "bidapi": {
            "Address": "http://bid-svc"
          }
        }
      }
    }
  }
}
